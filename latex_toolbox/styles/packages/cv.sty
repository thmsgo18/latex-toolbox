\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{cv}[2026/06/03 CV / Resume template style]

\RequirePackage{latexsym}
\RequirePackage{titlesec}
\RequirePackage{marvosym}
\RequirePackage[usenames,dvipsnames]{xcolor}
\RequirePackage{verbatim}
\RequirePackage{enumitem}
\RequirePackage{fancyhdr}
\RequirePackage{tabularx}
\RequirePackage{fontawesome5}
\RequirePackage{contour}
\RequirePackage[normalem]{ulem}
\RequirePackage{fontspec}
\setmainfont{TeX Gyre Heros}
\setmonofont[Scale=0.90]{Fira Mono}
\RequirePackage[a4paper, margin=0.5in]{geometry}
\RequirePackage[hidelinks]{hyperref}

% ---- Colors ----
\definecolor{light-grey}{gray}{0.83}
\definecolor{dark-grey}{gray}{0.3}
\definecolor{text-grey}{gray}{.08}

% ---- Custom underline ----
\renewcommand{\ULdepth}{1.8pt}
\contourlength{0.8pt}
\newcommand{\myuline}[1]{%
  \uline{\phantom{#1}}%
  \llap{\contour{white}{#1}}%
}

% ---- Page style ----
\pagestyle{fancy}
\fancyhf{}
\fancyfoot{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}

\urlstyle{same}
\raggedbottom
\raggedright
\setlength{\tabcolsep}{0in}

% ---- Section formatting ----
\titleformat{\section}{
    \bfseries \vspace{-5pt} \raggedright \normalsize
}{}{0em}{}[\color{light-grey}{\titlerule[2pt]} \vspace{-5pt}]

% ---- Resume commands ----
\newcommand{\resumeItem}[1]{
  \item\small{#1 \vspace{-2pt}}
}

% \resumeSubheading{Title}{Date}{Subtitle}{Location}
\newcommand{\resumeSubheading}[4]{
  \vspace{-1pt}\item
    \begin{tabular*}{\textwidth}[t]{l@{\extracolsep{\fill}}r}
      \textbf{#1} & {\color{dark-grey}\small #2}\vspace{-1pt}\\
      \textit{#3} & {\color{dark-grey}\small #4}\\
    \end{tabular*}\vspace{-4pt}
}

% \resumeSubSubheading{Title}{Date}
\newcommand{\resumeSubSubheading}[2]{
    \item
    \begin{tabular*}{\textwidth}{l@{\extracolsep{\fill}}r}
      \textit{\small#1} & \textit{\small #2} \\
    \end{tabular*}\vspace{-7pt}
}

% \resumeProjectHeading{Title}{Context}
\newcommand{\resumeProjectHeading}[2]{
  \item
  \begin{tabular*}{\textwidth}{l@{\extracolsep{\fill}}r}
    #1 & {\color{dark-grey}\small #2}\\
  \end{tabular*}\vspace{-4pt}
}

\newcommand{\resumeSubItem}[1]{\resumeItem{#1}\vspace{-4pt}}

\renewcommand\labelitemii{$\vcenter{\hbox{\tiny$\bullet$}}$}

\newcommand{\resumeSubHeadingListStart}{\begin{itemize}[leftmargin=0in, label={}]}
\newcommand{\resumeSubHeadingListEnd}{\end{itemize}}
\newcommand{\resumeItemListStart}{\begin{itemize}}
\newcommand{\resumeItemListEnd}{\end{itemize}\vspace{0pt}}

\color{text-grey}
