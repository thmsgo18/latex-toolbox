% Bibliographic references — BibTeX
% Compiled with Biber (biblatex, numeric-comp style)
%
% Cite a reference in the text with \cite{key}.
% Include without citing: \nocite{key}
%
% Common entry types:

@article{author2024,
  author  = {Last, First},
  title   = {Article Title},
  journal = {Journal Name},
  year    = {2024},
  volume  = {1},
  number  = {1},
  pages   = {1--10},
  doi     = {10.xxxx/xxxxx}
}

@online{website2024,
  author  = {Author or Organisation},
  title   = {Page Title},
  year    = {2024},
  url     = {https://example.com},
  urldate = {2024-01-01}
}

@book{book2023,
  author    = {Last, First},
  title     = {Book Title},
  publisher = {Publisher},
  year      = {2023},
  address   = {City}
}
