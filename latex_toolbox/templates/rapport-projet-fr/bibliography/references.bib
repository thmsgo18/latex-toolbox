% Références bibliographiques — BibTeX
% Compilées avec Biber (biblatex, style numeric-comp)
%
% Citez une référence dans le texte avec \cite{clé}.
% Pour inclure sans citer : \nocite{clé}
%
% Types d'entrées courants :

@article{auteur2024,
  author  = {Nom, Prénom},
  title   = {Titre de l'article},
  journal = {Nom de la revue},
  year    = {2024},
  volume  = {1},
  number  = {1},
  pages   = {1--10},
  doi     = {10.xxxx/xxxxx}
}

@online{site2024,
  author  = {Auteur ou Organisation},
  title   = {Titre de la page},
  year    = {2024},
  url     = {https://example.com},
  urldate = {2024-01-01}
}

@book{livre2023,
  author    = {Nom, Prénom},
  title     = {Titre du livre},
  publisher = {Éditeur},
  year      = {2023},
  address   = {Paris}
}
