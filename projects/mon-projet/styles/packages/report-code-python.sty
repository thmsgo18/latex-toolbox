\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{report-code-python}[2026/04/28 Shared Python code style for project reports]

\RequirePackage{listings}
\RequirePackage{styles/packages/report-colors}

\lstdefinestyle{pythonstyle}{
  language=Python,
  backgroundcolor=\color{LightGray},
  basicstyle=\ttfamily\footnotesize\color{TextGray},
  keywordstyle=\bfseries\color{ReportBlue},
  stringstyle=\color{StringRed},
  commentstyle=\itshape\color{CommentGreen},
  frame=single,
  rulecolor=\color{FrameGray},
  breaklines=true,
  breakatwhitespace=true,
  showstringspaces=false,
  tabsize=4,
  columns=fullflexible,
  xleftmargin=8pt,
  framexleftmargin=8pt,
  aboveskip=6pt,
  belowskip=6pt
}
